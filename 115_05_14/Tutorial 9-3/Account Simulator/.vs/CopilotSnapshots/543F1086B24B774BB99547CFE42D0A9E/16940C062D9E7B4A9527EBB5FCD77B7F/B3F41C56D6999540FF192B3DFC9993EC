using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace Account_Simulator
{
    public partial class Form1 : Form
    {
        private BankAccount account = new BankAccount(20000m);
        // BankAccount field with a $20000 starting balance 


        public Form1()
        {
            InitializeComponent();
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            // Display the starting balance.
            balanceLabel.Text = account.Balance.ToString("C");
        }

        private void depositButton_Click(object sender, EventArgs e)
        {
            // Get the deposit amount from the user.
            decimal amount = decimal.Parse(depositTextBox.Text);

            // Deposit the amount into the account.
            account.Deposit(amount);

            // Update the balance display.
            balanceLabel.Text = account.Balance.ToString("C");
        }

        private void withdrawButton_Click(object sender, EventArgs e)
        {
            // Get the withdrawal amount from the user.
            decimal amount = decimal.Parse(withdrawTextBox.Text);

            // Withdraw the amount from the account.
            account.Withdraw(amount);

            // Update the balance display.
            balanceLabel.Text = account.Balance.ToString("C");
        }
                            
        private void exitButton_Click(object sender, EventArgs e)
        {
            // Close the form.
            this.Close();
        }
    }
}
